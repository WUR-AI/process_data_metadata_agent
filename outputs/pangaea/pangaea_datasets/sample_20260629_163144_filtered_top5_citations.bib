@misc{greiffenhagen2026toca,
 author={Luis {Greiffenhagen} and J\"{u}rgen {Titschack} and Claudia {Wienberg} and Dierk {Hebbeln}},
 title={{Total organic carbon and total inorganic carbon content data of sediment core GeoB16310-2 from a coral mound in the Campeche Mound Province, Gulf of Mexico, MARIA S. MERIAN cruise MSM20/4}},
 year={2026},
 doi={10.1594/PANGAEA.987056},
 url={https://doi.org/10.1594/PANGAEA.987056},
 abstract={GeoB16310-2 is a gravity core taken from a coral mound (Ixchel Mound) in the Campeche Mound Province, Gulf of Mexico. Here we measure the TIC/TOC content in wt.{\%} from the mound{\textquotesingle}s sediments at a roughly comparable time interval, using a LECO CS 744 at the Department of Geosciences, University of Bremen, Germany. Thereby, sub-samples were measured for total carbon content before and after treatment with hydrochloric acid (i.e. TOC remains, TIC dissolves). TIC was calculated from the difference between TC and TOC (first and second measurement per sample). This contributes to a multi-step analysis of the core with the aim to calculate the total carbon accumulation (organic and inorganic carbon) within the mound.},
 type={dataset},
 publisher={PANGAEA}
}


@misc{apnmolina2020pmit,
 author={Juan Pablo {Ap\'{u}n-Molina} and M\'{a}ximo {Garc\'{\i}a-Marciano} and Apolinar {Santamar\'{\i}a-Miranda} and Juan {Violante-Gonzalez} and T Leticia {Espinosa-Carreon} and Juan Carlos {Sainz-Hern\'{a}ndez} and Jes\'{u}s T {Ponce-Palafox}},
 title={{Physicochemical measurements in the Macapule Lagoon (Gulf of California, Mexico) in 2013-2015}},
 year={2020},
 doi={10.1594/PANGAEA.917841},
 url={https://doi.org/10.1594/PANGAEA.917841},
 abstract={The Macapule Lagoon (25{\textordmasculine} 21{\textquotesingle} and 25{\textordmasculine} 24{\textquotesingle} N; 108{\textordmasculine} 30{\textquotesingle} and 108{\textordmasculine} 45{\textquotesingle} W) is part of the San Ignacio-Navachiste-Macapule lagoon system, located in the southern region of the Gulf of California (Fig. 1). In 2000, it has been declared an "Area of Reserve and Refuge for Migratory Birds and Wildlife {\textendash} Gulf of California Islands". This lagoon is very productive due to its location in the Gulf of California (Lluch-Cota et al. 2007). Water temperature, dissolved oxygen, pH, and salinity were measured in situ with an YSI (55-12FT) probe and a portable refractometer (RHS-10ATC). Nutrient (nitrate, ammonium, and phosphate) concentrations were determined in the laboratory during each sampling month using a photometer (YSI, 9500).},
 type={dataset},
 publisher={PANGAEA}
}


