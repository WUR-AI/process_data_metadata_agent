@incollection{lauer2025ldos,
 author={Tobias {Lauer} and Ema {Zvara} and Snje\v{z}ana {Pejdanovi\'{c}} and Peter {K\"{u}hn} and Christoph {Zielhofer} and Kathryn E {Fitzsimmons}},
 title={{Luminescence dating of sediment samples from NEP 1 and NEP 3, N\"{o}rdlingen, southern Germany}},
 year={2025},
 doi={10.1594/PANGAEA.973035},
 url={https://doi.org/10.1594/PANGAEA.973035},
 note={In: Zvara, Ema; Pejdanovi\'{c}, Snje\v{z}ana; Schneider, Birgit; Quante, Ella; Saeidi ghavi andam, Sara; Volosky, Diego; Lauer, Tobias; Fitzsimmons, Kathryn E; Marhan, Sven; Kandeler, Ellen; Poll, Christian; Oelmann, Yvonne; Neidhardt, Harald; Lindauer, Susanne; Friedrich, Ronny; Werther, Lukas; Frenzel, Peter; K\"{u}hn, Peter; Zielhofer, Christoph (2025): Multidisciplinary analyses of sediment-soil profiles from the Eger floodplain (N\"{o}rdlingen, southern Germany) [dataset bundled publication]. PANGAEA, https://doi.org/10.1594/PANGAEA.972856},
 abstract={We established a luminescence based chronology by dating 7 samples collected from profiles NEP 1 and NEP 3. The methods allows to determine the last sunlight exposure of sediment grains (commonly quartz and feldspar). All measurements were conducted in the luminescence laboratory within the Geo-and Environmental research center in T\"{u}bingen. We used a so called pIR150 protocol on polyminerals. The results point to various periods of deposition between approximately 1-8 ka.},
 type={dataset},
 publisher={PANGAEA}
}


@misc{massari2026hmco,
 author={Francesco {Massari} and Maria Giuditta {Fellin} and Cristina {Stefani} and Eva {Enkelmann} and Iginio {Dieni} and Stefano {Sanchetti}},
 title={{Heavy mineral composition of the Lanaittu Sandstone in Eastern Sardinia, Italy}},
 year={2026},
 doi={10.1594/PANGAEA.995327},
 url={https://doi.org/10.1594/PANGAEA.995327},
 abstract={Analyses of Lanaittu Sandstone (middle-upper Campanian, Eastern Sardinia, Italy), recovered from a geognostic well cored in 1989, permit reconstruction of the paleogeography of this area. Heavy mineral associations were analyzed in the 60-250 $\mu$m fraction of selected arenites. Samples were crushed and sieved to <4 mm, then disaggregated by etching with 10{\%} hydrochloric acid to remove carbonate and apatite. For gravity separation, tetrabromoethane (density 2.967 g/cm${^3}$) was used. The ribbon method was used for quantitative analysis until 200 transparent grains were determined (Gazzi et al., 1973). The transparent heavy mineral assemblage includes rare glaucophane-crossite combined, up to 13{\%} kyanite, and trace amounts of lawsonite, indicating a HP-LT metamorphic source.},
 type={dataset},
 publisher={PANGAEA}
}


