@misc{hoppe2026caci,
 author={Clara Jule Marie {Hoppe} and John Paul {Balmonte} and Tina {Brenneis} and Giulia {Castellani} and Emelia {Chamberlain} and Jessie {Creamean} and Elise Sayana {Droste} and Lena {Eggers} and Allison A {Fong} and Jessie {Gardner} and Laura {Heitmann} and Musheng {Lan} and Jian {Ren} and Pauline {Snoeijs-Leijonmalm} and Susanne {Spahic} and Anders {Svenson} and Anja {Terbr\"{u}ggen} and Anders {Torstensson} and Adam {Ulfsbo} and Martina {Vortkamp} and Yanpei {Zhuang}},
 title={{Chlorophyll a  concentrations in second year sea ice during the MOSAiC expedition (PS122) in the Central Arctic Ocean 2019-2020}},
 year={2026},
 doi={10.1594/PANGAEA.990054},
 url={https://doi.org/10.1594/PANGAEA.990054},
 abstract={Concentrations of Chlorophyll a and phaeopigments from sectioned ice cores taken from second year sea ice  during the MOSAiC (PS122) drift expedition in the central Arctic Ocean. Ice sections were pooled per depth layer, melted in filtered seawater, filtered onto precombusted GF/F filters (nominal pore size 0.7$\mathrm{\mu}$m) and frozen at -80{\textdegree}C. Samples were subsequently extracted in 90{\textdegree}C acetone, homogenized using a cell mill,  and measured on the following day using a Turner flourometer, followed by an acidification step to determine pheopigments (see Knap et al. 1994 for details and calculations). Details on sampling and processing can be found in Fong et al. 2024.},
 type={dataset},
 publisher={PANGAEA}
}


@incollection{prezcrdenas2024sdoa,
 author={Nathalia {P\'{e}rez-C\'{a}rdenas} and Maarten B {Eppinga} and Ryan {Rabett} and Meredith C {Schuman} and Maria J {Santos}},
 title={{Spatiotemporal Distribution of Archaeological Sites in Borneo Over the Last 45,000 Years, with Emphasis on the Mid-Late Holocene (Last 6,000 Years) [chronology]}},
 year={2024},
 doi={10.1594/PANGAEA.973041},
 url={https://doi.org/10.1594/PANGAEA.973041},
 note={In: P\'{e}rez-C\'{a}rdenas, N et al. (2024): Spatiotemporal Distribution of Archaeological Sites in Borneo Over the Last 45,000 Years, with Emphasis on the Mid-Late Holocene (Last 6,000 Years) [dataset bundled publication]. PANGAEA, https://doi.org/10.1594/PANGAEA.973047},
 abstract={The dataset comprises 73 archaeological and historical sites across Borneo, a valuable resource for researchers interested in regional Bornean human occupation and settlement. It covers a period of 45 ka before the present (BP) to 0 BP (1950 CE), with a specific focus on the last 6 ka BP. The dataset provides detailed information on the location, timing, and duration of human occupation at each site, based on archaeological surveys. This compilation enables the study of resource use and their landscape legacies, making it an indispensable tool for understanding the regional Bornean human occupation and settlement. The archaeological site database was constructed based on a review of published reports and articles (see Perez-Cardenas et al., 2024).  \\
We reviewed and categorized each record between i) no radiocarbon data, such as U-series and U-Th dating, ii) calibrated radiocarbon, and iii) uncalibrated radiocarbon. Then, calibrated and uncalibrated radiocarbon were recalibrated to 95.4{\%} confidence using the atmospheric curve IntCal20, OxCal 4.4 (Reimer et al., 2020). The dates obtained using Uranium were not calibrated. The lab code used in the original reference is provided for each record. We subset the dataset, obtaining 47 archaeological sites, by selecting sites with records over the last 6 ka BP to extract environmental characteristics. We created a matrix with the time and duration of occupation of archaeological evidence in 100-year intervals from 6 ka BP to 0 BP (1950 CE) for each site.},
 type={dataset},
 publisher={PANGAEA}
}


@misc{lskow2024ecar,
 author={Florian {L\"{u}skow} and Tanya {Balaji} and Evgeny A {Pakhomov}},
 title={{Elemental composition and residual water content of seven thaliacean (salps and pyrosomes) species from the world{\textquotesingle}s oceans}},
 year={2024},
 doi={10.1594/PANGAEA.961147},
 url={https://doi.org/10.1594/PANGAEA.961147},
 abstract={Ecosystem models often use wet weights to parameterise biota disregarding their water content. This may be especially erroneous for gelatinous plankton, such as salps and pyrosomes, with high, compared to crustaceans, water content. Poorly quantified residual water should also be corrected when using dry weights for parameterisation. We estimated the residual water content (as well as elemental and organic contents) for seven tunicate species, one pyrosome and six salps (N = 107). Specimens were collected during several research expeditions in the Southern Ocean, the Northeast Pacific, east of New Zealand, and around Hawaii between 2004 and 2021. The residual water content of tunicates was analyzed for inter- and intraspecific variability. The H-surplus method (Madin et al. 1981) was applied for the residual water content calculation. The dataset contains information about the life cycle stage (blastozooid versus oozooid), tissue type (tunic versus whole organism), drying method (oven versus freeze-drying), size, and the elemental and organic contents of the samples. The methods and results of the study are described in detail in L\"{u}skow et al. (submitted).},
 type={dataset},
 publisher={PANGAEA}
}


@misc{brown2024sdfs,
 author={Ian A {Brown} and Johan {Casselgren} and Andrew {Mercer} and Annika {Kristoffersson}},
 title={{Snow density from shallow cores in western Dronning Maud Land, Antarctica , acquired during the Swedish Antarctic Expedition 2021/22}},
 year={2024},
 doi={10.1594/PANGAEA.968881},
 url={https://doi.org/10.1594/PANGAEA.968881},
 abstract={The data were acquired during the austral summer of 2021/22 as part of the Swedish Antarctic Program (SWEDARP) expedition DML21/22. During the expedition we drilled snow cores with a PICO auger at 23 locations around the research stations of Wasa (Sweden) and Aboa (Finland). 2 cores were acquired on the Riiser-Larsen ice shelf. The cores were between approximately 3 and 6 meters deep. Cores were sampled in 5-20 cm segments, mostly, and the segments were bagged and weighed with a precision spring balance. The spring balance was tested for precision and accuracy at the start of the field season. We collected the data as part of an investigation into synthetic aperture radar penetration and scattering.},
 type={dataset},
 publisher={PANGAEA}
}


@misc{kurihara2008scca,
 author={Haruko {Kurihara} and Takamasa {Asai} and Shoji {Kato} and Atsushi {Ishimatsu}},
 title={{Seawater carbonate chemistry and early development of the oyster Crassostrea gigas}},
 year={2008},
 doi={10.1594/PANGAEA.924558},
 url={https://doi.org/10.1594/PANGAEA.924558},
 abstract={We investigated the effects of seawater equilibrated with CO2-enriched air (2000 ppm, pH 7.4) on the early development of the mussel Mytilus galloprovincialis. Mussel embryos were incubated for 144 h (6 d) in control and high-CO2 seawater to compare embryogenesis, larval growth and morphology with ordinary light, polarized light, and scanning electron microscopy. Embryogenesis was unaffected by exposure to high-CO2 seawater up to the trochophore stage, but development at the trochophore stage was delayed when the shell began to form. All veliger larvae of the high-CO2 group showed morphological abnormalities such as convex hinge, protrusion of the mantle and malformation of shells. Larval height and length were 26 +- 1.9{\%} and 20 +- 1.1{\%} smaller, respectively, in the high-CO2 group than in the control at 144 h. These results are consistent with our previous findings of CO2 effects on early development of the oyster Crassostrea gigas, although the severity of CO2 damage appears to be less in M. galloprovincialis, possibly due to differing spawning seasons (oyster: summer; mussel: winter). Results from this and the previous study indicate that high CO2 (2000 ppm) interferes with early development, particularly with larval shell synthesis, of bivalves; however, vulnerability to high CO2 differs between species. Taken together with recent studies demonstrating negative impacts of high CO2 on adult mussels and oysters, results imply a future decrease of bivalve populations in the oceans, unless acclimation to the predicted environmental alteration occurs.},
 type={dataset},
 publisher={PANGAEA}
}


@misc{girard2025upps,
 author={Juliette {Girard} and Brendan T {Reilly} and Guillaume {St-Onge} and France {Lagroix} and Jean-Carlos {Montero-Serrano} and Joseph S {Stoner} and Anne E {Jennings}},
 title={{Updated paleomagnetic Petermann stack (inclination, declination, relative paleointensity, Virtual Geomagnetic Pole) from Petermann Fjord (Nares Strait, Northern Greenland)}},
 year={2025},
 doi={10.1594/PANGAEA.971851},
 url={https://doi.org/10.1594/PANGAEA.971851},
 abstract={This paleomagnetic stack was built using cores AMD1902-10GC (data available in PANGAEA, Girard et al., 2024), cores OD1507-04GC, OD1507-41GC, OD1507-40TC (data available in MagIc, Reilly et al., 2019). The stack was calculated as follow: Bin widths of 5 cm CED were used to calculate the Fisher mean of the directions  with N the number of cores contributing to the stack for each calculation. The virtual geomagnetic pole (VGP) coordinates were calculated assuming stack declination rotation of 125 degrees +/- 20 degrees.},
 type={dataset},
 publisher={PANGAEA}
}


@incollection{gottschalk2021tbmm,
 author={Matthias {Gottschalk} and Ulrike {Egerer}},
 title={{Tethered balloon-borne meteorological measurements during the Arctic field campaign AO2018 (Balloon$\_$20180818$\_$1109$\_$1139)}},
 year={2021},
 doi={10.1594/PANGAEA.927062},
 url={https://doi.org/10.1594/PANGAEA.927062},
 organization={Leibniz-Institut f\"{u}r Troposph\"{a}renforschung e.V., Leipzig},
 note={In: Gottschalk, M; Egerer, U (2021): Tethered balloon-borne measurements of turbulence and radiation during the Arctic field campaign Arctic Ocean 2018 in August/ September 2018 [dataset bundled publication]. PANGAEA, https://doi.org/10.1594/PANGAEA.927100},
 abstract={The tethered balloon system BELUGA (Balloon-bornE moduLar Utility for profilinG the lower Atmosphere) was operated from an ice floe next to IB ODEN (around 89{\textdegree}37.0{\textquotesingle} N , 40{\textdegree}46.5{\textquotesingle}E). The measurements were taken during the AO2018 (Arctic Ocean) - MOCCHA (Microbiology-Ocean-Cloud Coupling in the High Arctic) campaign on 14 days in the period 18 August to 13 September 2018. For this campaign, a 9 m${^3}$ helium filled balloon with modular instrumentation was used. This dataset contains standard meteorological data based on a GRAW DFM-09 radiosonde with additional wind speed measurements by a Pitot-static probe.},
 type={dataset},
 publisher={PANGAEA}
}


@misc{plenzler2024dmdf,
 author={Joanna {Plenzler}},
 title={{Daily meteorological data from automatic weather station Puchalski, King George Island, during 2018-2023}},
 year={2024},
 doi={10.1594/PANGAEA.969067},
 url={https://doi.org/10.1594/PANGAEA.969067},
 abstract={Presented dataset contains meteorological data from Puchalski automatic weather station located at 55 m a.s.l. at western shore of Admiralty Bay (King George Island, West Antarctica) during 2018.01.01 {\textendash} 2023.12.31. The dataset contains daily mean, maximum and minimum values of air temperature [{\textdegree}C], relative air humidity [{\%}], wind speed [m/s] and daily sum of solar radiation [MJ/m2]. Mean values of air temperature and humidity and wind speed were calculated from measurements taken every 10 minutes. Non-processed data were used for identification of extreme values. Daily sum of solar radiation were calculated from solar radiation intensity measured every 10 minutes. Automatic weather station has a data logger manufactured by Campbell with following sensors: Vaisala temperature and humidity probe, Setra barometer, Gill Wind Sonic anemometer and Apogee pyranometer. Presented data may serve as a background for other research projects conducted at King George Island as well as an analyse of meteorological conditions itself. They could also be useful in evaluation of management plans of Antarctic Special Protected Areas located at King George Island.},
 type={dataset},
 publisher={PANGAEA}
}


@misc{spruzen2024acop,
 author={Charlotte {Spruzen} and Harold J {Bradbury} and Emma R {Kast} and Alexandra V {Turchyn}},
 title={{A compilation of published pyrite sulfur isotopic compositions from the past 165 million years}},
 year={2024},
 doi={10.1594/PANGAEA.972993},
 url={https://doi.org/10.1594/PANGAEA.972993},
 abstract={This dataset contains a compilation of the sulfur isotopic composition of pyrite from outcrop and sediment cores over the past 165 million years. The compilation includes 3754 data points from 94 publications, compiled in 2020, 2021, and 2023. The data was collected in order to investigate the relationship between the sulfur isotopic composition of pyrite and depositional environment over the Cenozoic and Late Mesozoic, and has global spatial coverage. Compiled sediment core data includes the sulfur isotopic composition of pyrite, age, water depth, location, methane content, lithology, and total organic carbon. Compiled outcrop data includes the sulfur isotopic composition of pyrite, age, generalized water depth based on sedimentological criteria, and lithology.},
 type={dataset},
 publisher={PANGAEA}
}


@misc{bagheridastgerdi2021cswv,
 author={Saeid {Bagheri Dastgerdi} and Melanie {Behrens} and Jean-Louis {Bonne} and Maria {H\"{o}rhold} and Gerrit {Lohmann} and Elisabeth {Schlosser} and Martin {Werner}},
 title={{Continuous surface water vapour isotope monitoring at Neumayer Station III (201702-201901)}},
 year={2021},
 doi={10.1594/PANGAEA.939047},
 url={https://doi.org/10.1594/PANGAEA.939047},
 abstract={This dataset presents the first fully continuous monitoring of water vapour isotopic composition at Neumayer Station III, Antarctica, for two years, from February 2017 to January 2019. In January 2017, a PICARRO L2140-i cavity ring-down spectroscopy analyser was installed in a laboratory room at Neumayer Station. The Picarro analyser runs continuously and measures the injected water vapour content and its isotopic composition approximately every two seconds. For our analyses, the data are reported as hourly mean values.},
 type={dataset},
 publisher={PANGAEA}
}


