@misc{greiffenhagen2026toca,
 author={Luis {Greiffenhagen} and J\"{u}rgen {Titschack} and Claudia {Wienberg} and Dierk {Hebbeln}},
 title={{Total organic carbon and total inorganic carbon content data of sediment core GeoB16310-3 from a coral mound in the Campeche Mound Province, Gulf of Mexico, MARIA S. MERIAN cruise MSM20/4}},
 year={2026},
 doi={10.1594/PANGAEA.987068},
 url={https://doi.org/10.1594/PANGAEA.987068},
 abstract={GeoB16310-3 is a gravity core taken from a coral mound (Ixchel Mound) in the Campeche Mound Province, Gulf of Mexico. Here we measure the TIC/TOC content in wt.{\%} from the mound{\textquotesingle}s sediments at a roughly comparable time interval, using a LECO CS 744 at the Department of Geosciences, University of Bremen, Germany. Thereby, sub-samples were measured for total carbon content before and after treatment with hydrochloric acid (i.e. TOC remains, TIC dissolves). TIC was calculated from the difference between TC and TOC (first and second measurement per sample). This contributes to a multi-step analysis of the core with the aim to calculate the total carbon accumulation (organic and inorganic carbon) within the mound.},
 type={dataset},
 publisher={PANGAEA}
}


