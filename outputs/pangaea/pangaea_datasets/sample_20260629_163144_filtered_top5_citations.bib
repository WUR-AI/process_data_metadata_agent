 author={Sebastian {Zeppenfeld} and Manuela {van Pinxteren} and Susanne {Fuchs} and Markus {Hartmann} and Xianda {Gong} and Hartmut {Herrmann}},
 title={{Inorganic ions in size-resolved aerosol particles sampled from the Arctic in 2017}},
