@misc{rantala2026xfcs,
 author={Marttiina V {Rantala} and Isabel {Israde-Alc\'{a}ntara} and Reza {Safaierad} and Nadine {Mattielli} and Wojciech {Tylmann} and John P {Smol} and Christopher {Grooms} and Gilles {Lepoint} and Pierre {Francus} and Sarah {Metcalfe} and Pawe{\l} {Etma\'{n}ski} and Nathalie {Fagel}},
 title={{X-ray fluorescence core scanning (XRF-CS) data of a sediment core from Lake Tepetiltic (Nayarit, Mexico)}},
