 title={{Boulders and tree trunks (LW) moved during flash flood 2018 in the Sucha Woda Stream, Tatra Mountains}},
 year={2024},
 doi={10.1594/PANGAEA.974037},
 url={https://doi.org/10.1594/PANGAEA.974037},
 abstract={The dataset includes data on boulders and tree trunks (LW) moved and transported during the major flash flood in the Sucha Woda Stream in the Tatra Mountains on 18 July 2018.. The aim of the study was to determine the geomorphological effects of the flood and the impact of flash floods on a gravel-bed mountain stream. The effects of the flood were assessed immediately after the event. At 11 selected sites, the maximum diameter of the 25 largest boulders moved during the flood was measured with a tape measure, to an accuracy 0.5 cm. At the same sites, the number of tree trunks was counted and divided into trunks aligned with or transverse to the course of the stream.  Garmin Oregon 300 and Garmin eTrex 20 GPS were used in the studies.},
 type={dataset},
 publisher={PANGAEA}
}


