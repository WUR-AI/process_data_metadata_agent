@misc{nrnberg2025scao,
 author={Dirk {N\"{u}rnberg} and Nadine {Gehre} and Sebastian {Fessler}},
 title={{Stable carbon and oxygen isotopes of benthic Uvigerina spp. in core M78/1$\_$181-3}},
 year={2025},
 doi={10.1594/PANGAEA.975181},
 url={https://doi.org/10.1594/PANGAEA.975181},
 abstract={The Mississippi River discharge effectively shaped the dynamics of the Loop Current in the Gulf of Mexico during transient climates and interglacials, and reacted in response to changes in sea level and atmospheric circulation. We here provide proxydata records from piston core M78/1-181-3 PC. The {\textasciitilde}12 m-long core was recovered from the Mississippi Alabama shelf very close to and southeast of the recent Mississippi delta (29{\textdegree}00.00{\textquotesingle}N 88{\textdegree}20.00{\textquotesingle}W) from 804 m water depth during R/V Meteor Cruise M78/1 in 2009 (doi:10.2312/cr$\_$m78$\_$1). The proxyrecords cover the last {\textasciitilde}42 kyrs at centennial resolution. Stable oxygen ($\delta$18O, {\textperthousand} VPDB) and carbon isotope analyses ($\delta$13C; {\textperthousand} VPDB) were performed on the benthic foraminiferal species Uvigerina spp. Sampling and analytical studies were carried out from 3 cm to {\textasciitilde}1220 cm core depth at {\textasciitilde}5 cm spatial resolution. The stable isotope analyses were run on a Thermo Scientific MAT 253 mass spectrometer with an automated Kiel IV Carbonate Preparation Device at GEOMAR. The isotope data provide stratigraphical and intermediate water information.},
 type={dataset},
 publisher={PANGAEA}
}


@incollection{schaafsma2024iopc,
 author={Fokje L {Schaafsma} and Hauke {Flores} and Carmen Lucia {David} and Giulia {Castellani} and Serdar {Sakinan} and Nicole {Hildebrandt} and Apasiri {Klasmeier} and Katrin {Schmidt}},
 title={{Information on polar cod (Boreogadus saida) from the central Arctic Ocean, used for stomach content analysis}},
