@misc{vonsuchodoletz2025adoa,
 author={Hans {von Suchodoletz} and Birgit {Schneider} and Anna {Skokan} and Teresa {Nitz} and Bruno {Glaser} and Steven {Polivka} and Katja {Wiedner} and Frank {Schl\"{u}tz} and Torsten {Schunke} and Peter {K\"{u}hn}},
 title={{Analytical data of a buried and a recent surficial Chernozem in the Bornh\"{o}ck area in Central Germany}},
 year={2025},
 doi={10.1594/PANGAEA.982395},
 url={https://doi.org/10.1594/PANGAEA.982395},
 abstract={This dataset contains analytical data of two studied soil profiles, one of a buried (BH-II) and one of a recent surficial Chernozem (BH-rec) in the Bornh\"{o}ck area in Central Germany (southern Saxony-Anhalt). At BH-II, the Chernozem was buried by the Early Bronze Age burial mound {\textquotesingle}Bornh\"{o}ck{\textquotesingle} about 3.8 ka. The study area is described in Suchodoletz et al. (2023). During our research we measured grain sizes, organic carbon and carbonate contents, black carbon, soil isotopes, elements and lignin phenols (S/V and C/V). The measurements were performed between 2019 and 2024. The goal of our study was to evaluate regional soil formation and human impact since the Early Bronze.},
 type={dataset},
 publisher={PANGAEA}
}


@misc{strasser2025xdrf,
 author={Michael {Strasser} and Ken {Ikehara} and Jeremy D {Everest} and Lena {Maeda} and Katharina {Hochmuth} and Hannah {Grant} and Margaret S {Stewart} and Noriaki {Sakurai} and Takahiro {Yokoyama} and Rui {Bao} and Piero {Bellanova} and Morgane {Brunet} and Zhirong {Cai} and Antonio {Cattaneo} and Kan-Hsi {Hsiung} and Jyh-Jaan Steven {Huang} and Tahashi {Ishizawa} and Takuya {Itaki} and Kana {Jitsuno} and Joel E {Johnson} and Toshiya {Kanamatsu} and Myra {Keep} and Arata {Kioka} and Martin {K\"{o}lling} and Min {Luo} and Christian {M\"{a}rz} and Cecilia M G {McHugh} and Aaron {Micallef} and Yoshitaka {Nagahashi} and Dhananjai K {Pandey} and Jean-No\"{e}l {Proust} and Troy {Rasbury} and Natascha {Riedinger} and Yasufumi {Satoguchi} and Derek E {Sawyer} and Chlo\'{e} {Seibert} and Maxwell {Silver} and Susanne M {Straub} and Joonas J {Virtasalo} and Yong Hong {Wang} and Ting-Wei {Wu} and Sarah D {Zellers}},
 title={{X-ray diffraction results from IODP Hole 386-M0095B}},
 year={2025},
 doi={10.1594/PANGAEA.978983},
 url={https://doi.org/10.1594/PANGAEA.978983},
 abstract={Results of X-ray diffraction (XRD) analyses from the above given hole of International Ocean Discovery Program (IODP) Expedition 386 (Japan Trench Paleoseismology). The offshore phase of this expedition took place between 2021-04-13 and 2021-06-01 onboard Japanese R/V Kaimei from and to Yokosuka, Japan, followed by an onshore phase onboard D/V Chikyu between 2022-02-14 {\textendash} 2022-03-15. During the onshore phase a set of solid-phase samples, with a volume of approx. 10 cubic centimeters each, were taken with the purpose to be later on split into aliquots for the following three analyses: X-ray diffraction, carbon and X-ray fluorescence. The bulk solid-phase samples were taken from the work halves of core sections at about one sample per meter on average. Unprocessed samples were then shipped to the MARUM - Center for Marine Environmental Sciences of the University of Bremen (Germany), where they were freeze-dried, ground and homogenized to a fine powder (<20 $\mathrm{\mu}$m particle size) by ECORD Science Operator staff using a pestle and an agate mortar. The aliquots for XRD analysis were prepared with the Philips backloading system in the Crystallography and Geomaterials Research laboratories of the Geoscience Department at the University of Bremen (Germany). X-ray diffractograms were measured on a Bruker D8 Discover diffractometer. Mineral identification and semi-quantification were done using the Philips software X{\textquotesingle}Pert HighScore Version 1.2 (Degen et al., 2014, https://doi.org/10.1017/S0885715614000840) and follows concepts of Vogt (2009, https://doi.org/10.2204/iodp.proc.302.203.2009). Minimum relative errors are given based on Vogt et al., 2002 (https://doi.org/10.1346/000986002760833765). Clay Mineral groups are used as sums of multiple minerals. In many samples there is a bulb below 20-25{\textdegree} 2theta pointing to amorphous SiO2, which can be biogenic (e.g. diatoms etc.) or volcanic glass. The bulb size could implicate about 10-20 wt.{\%} of amorphous SiO2. Exact quantification of this component would require more detailed XRD experiments.\\
For further methodological information see methods chapter in\hspace{0.167em}Strasser, M. et al., 2023 https://doi.org/10.14379/iodp.proc.386.102.2023},
 type={dataset},
 publisher={PANGAEA}
}


