 publisher={PANGAEA}
}


@misc{elbizri2019ilcf,
 author={Hani Rocha {El Bizri} and John E {Fa} and L\'{\i}sley P {Lemos} and Carlos F A {Vasconcelos Neto} and Jo\~{a}o Vitor {Campos-Silva} and Jo\~{a}o {Vasecchi} and Stefan {Lippl} and Alejo {Cochachin} and Pedro {Mayor}},
 title={{Involving local communities for effective citizen science: determining game species{\textquotesingle} reproductive status to assess hunting effects in tropical forests}},
 year={2019},
 doi={10.1594/PANGAEA.906209},
 url={https://doi.org/10.1594/PANGAEA.906209},
 abstract={These three datasets are related to the analyses conducted in the article "Involving local communities for effective citizen science: determining game species{\textquotesingle} reproductive status to assess hunting effects in tropical forests".\\
\\
The first dataset (1$\_$Archive$\_$Interviews$\_$Pregnancy$\_$Diagnoses$\_$Final) consists of interviews through which diagnoses of reproductive status of lowland paca (Cuniculus paca) were performed by local people in the Amazon.\\
\\
The second dataset (2$\_$Archive$\_$Hunting$\_$Registers$\_$Pregnancy$\_$Immatures) consists of all records of pacas hunted voluntarily collected by local people over a 17-years citizen science project in one of the study sites.\\
\\
The third dataset (3$\_$Archive$\_$Hunting$\_$Registers$\_$CPUE) consists of data on the catch-per-unit-effort of lowland paca hunting events in the same site over 17 years.\\
\\
Specific explanations of columns{\textquotesingle} attributes are presented in the sheet "Explanations" within each dataset.\\
\\
The study areas and the coordinates related to the dataset are:\\
\\
Aman\~{a} Sustainable Development Reserve: -64.538 W; -2,492 S\\
Yavar\'{\i}-Mir\'{\i}n River:-71,958 W; - 4,357 S\\
Juru\'{a} River: -67,659 W; -5,517 S},
 type={dataset},
 publisher={PANGAEA}
}


