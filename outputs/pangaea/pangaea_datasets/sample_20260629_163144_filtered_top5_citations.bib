@misc{greiffenhagen2026toca,
 author={Luis {Greiffenhagen} and J\"{u}rgen {Titschack} and Claudia {Wienberg} and Dierk {Hebbeln}},
 title={{Total organic carbon and total inorganic carbon content data of sediment core GeoB16320-2 from a drift deposit, Campeche Mound Province, Gulf of Mexico, MARIA S. MERIAN cruise MSM20/4}},
 year={2026},
 doi={10.1594/PANGAEA.987071},
 url={https://doi.org/10.1594/PANGAEA.987071},
 abstract={GeoB16320-2 is a gravity core taken from a sediment drift deposit in proximity to the Campeche Mound Province, Gulf of Mexico at 626 m water depth. The core is used as off-mound core to compare the sedimentary dynamics of the coral mounds (on-mound cores) with the surrounding environment (this core). Here we measure the TIC/TOC content in wt.{\%} from the off-mound sediments at a roughly comparable time interval, using a LECO CS 744 at the Department of Geosciences, University of Bremen, Germany. Thereby, sub-samples were measured for total carbon content before and after treatment with hydrochloric acid (i.e. TOC remains, TIC dissolves). TIC was calculated from the difference between TC and TOC (first and second measurement per sample). This contributes to a multi-step analysis of the core with the aim to calculate the total carbon accumulation (organic and inorganic carbon) of the off-mound environment in the Campeche Mound Province.},
 type={dataset},
 publisher={PANGAEA}
}


@incollection{hill2025proc,
 author={Claudia E L {Hill} and Julia {R\"{u}cker} and Nele {Eichhorn} and Selma D {Mezger} and Giulia {Caporale} and Yusuf C {El-Khaled} and Sahara {Blanco} and Christian {Wild} and Arjen {Tilstra}},
 title={{Pulsation rate of coral Xenia umbellata in a aquarium experiment}},
 year={2025},
 doi={10.1594/PANGAEA.974800},
 url={https://doi.org/10.1594/PANGAEA.974800},
 note={In: Hill, CEL et al. (2025): Excess particulate organic matter negatively affects the ecophysiology of the widespread soft coral Xenia umbellata [dataset bundled publication]. PANGAEA, https://doi.org/10.1594/PANGAEA.974797},
 abstract={Pulsations were recorded every 7 days from one colony per tank on three polyps. A pulsation was defined as a full contraction cycle. Counts were taken for 30 seconds in the morning using a tally counter, with water flow pumps off to prevent interference. To minimise bias, the same observer recorded all counts. Pulsation rate (pulsations per minute) was calculated by doubling the count and averaging three replicates per colony. Xenia umbellata originates from the Red Sea.},
 type={dataset},
 publisher={PANGAEA}
}


